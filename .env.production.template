# Production Environment Configuration Template
# Copy this file to .env.production and replace all placeholder values with your actual credentials
# NEVER commit .env.production with real credentials to git!

NODE_ENV=production
PORT=5000

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_IN_PRODUCTION

# Database - Turso (LibSQL Cloud)
TURSO_DATABASE_URL=your_production_database_url
TURSO_AUTH_TOKEN=your_production_auth_token

# AI Services - Dual API Keys for Load Balancing
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_SAFETRACE=your_gemini_api_key_safetrace_here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MODEL_NEXA=gemini-2.5-flash

# SafeTrace Navigation
OPENROUTE_API_KEY=your_openroute_api_key_here

# Admin Credentials
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_secure_admin_password

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
